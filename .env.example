# Template for local credentials (LLM keys, API secrets) — Owner: Joseph
#
# Copy this file to `.env` (gitignored) and fill in as needed:
#     cp .env.example .env
#
# The deterministic backend needs NO keys — Open-Meteo and NOAA are public APIs.
# Everything below is optional overrides + placeholders for the AI lanes.

# --- Weather services (optional; defaults live in app/core/config.py) ---
# OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
# REQUEST_TIMEOUT_S=10
# NOAA_POINTS_URL=https://api.weather.gov/points
# NOAA_USER_AGENT=usnrl-weather-router (https://github.com/krithika0827/usnrl-weather-router)

# --- AI / LLM (Krithika, Week 4 — not used by the backend yet) ---
# LLM_API_KEY=
